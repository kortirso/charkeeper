<table class="table w-full text-sm">
  <thead>
    <tr>
      <td></td>
      <td>ID</td>
      <td>Name</td>
      <td>Class name</td>
      <td>Spellcast</td>
      <td>Mechanics</td>
      <td></td>
      <td></td>
      <td></td>
      <td></td>
    </tr>
  </thead>
  <tbody>
    <% @subclasses.each_with_index do |subclass, index| %>
      <tr>
        <td class="pr-2"><%= (@pagy.page - 1) * 25 + index + 1 %></td>
        <td class="pr-2"><%= subclass.id %></br><%= subclass.user_id %></td>
        <td class="pr-2"><%= subclass.title %></td>
        <td class="pr-2"><%= @classes[subclass.info.class_id] ? "HB #{translate(@classes[subclass.info.class_id])}" : subclass.info.class_id %></td>
        <td class="pr-2"><%= subclass.info.spellcast %></td>
        <td class="pr-2"><%= subclass.info.mechanics %></td>
        <td class="pr-2"><%= subclass.created_at.strftime('%d-%m-%Y') %></td>
        <td class="pr-2"><%= subclass.discarded? ? 'deleted' : '' %></td>
        <td><%= link_to 'Edit', edit_adminbook_homebrew_path(subclass.id) %></td>
        <td><%= link_to "Download", adminbook_homebrew_download_report_path(subclass.id) %></td>
      </tr>
    <% end %>
  </tbody>
</table>
<% if @pagy.pages > 1 %>
  <div class="mt-6"><%== pagy_nav(@pagy) %></div>
<% end %>
