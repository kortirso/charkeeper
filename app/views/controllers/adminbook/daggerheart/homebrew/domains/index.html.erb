<table class="table w-full text-sm">
  <thead>
    <tr>
      <td></td>
      <td>ID</td>
      <td>Name</td>
      <td>User ID</td>
      <td></td>
      <td></td>
    </tr>
  </thead>
  <tbody>
    <% @domains.each_with_index do |domain, index| %>
      <tr>
        <td class="pr-2"><%= (@pagy.page - 1) * 25 + index + 1 %></td>
        <td class="pr-2"><%= domain.id %></td>
        <td class="pr-2"><%= domain.title %></td>
        <td class="pr-2"><%= domain.user_id %></td>
        <td class="pr-2"><%= domain.created_at.strftime('%d-%m-%Y') %></td>
        <td><%= link_to 'Edit', edit_adminbook_homebrew_path(domain.id) %></td>
      </tr>
    <% end %>
  </tbody>
</table>
<% if @pagy.pages > 1 %>
  <div class="mt-6"><%== pagy_nav(@pagy) %></div>
<% end %>
