[
  {
    /* required, allowed locale keys - en, ru, es */
    "title": {
      "en": "Subclass's title"
    },
    /* required, allowed locale keys - en, ru, es */
    "description": {
      "en": "Subclass's description, **Markdown is available** for editing."
    },
    "public": false,
    /* required, parent class */
    /* bard, druid, guardian, ranger, rogue, seraph, sorcerer, warrior, wizard or ID of homebrew class */
    "class_id": "bard",
    /* optional, spellcast trait */
    /* agi, str, fin, ins, pre, know */
    "spellcast": null,
    /* "spellcast": "agi", */
    /* optional, available mechanics, list can be empty */
    /* beastform, companion, stances */
    "mechanics": ["companion"],
    "features": [
      {
        /* required, allowed locale keys - en, ru, es */
        "title": {
          "en": "Feature's title"
        },
        /* required, allowed locale keys - en, ru, es */
        "description": {
          "en": "Feature's description, **Markdown is available** for editing."
        },
        /* required, allowed values - static/text/update_result/hidden */
        /* static - Simple rendering */
        /* text - Like static + allow to add text value */
        /* update_result - Like static + can be hidden by settings */
        /* hidden - Always hidden */
        "kind": "static",
        /* optional */
        "limit": 1,
        /* optional, allowed values - short_rest/long_rest/session */
        "limit_refresh": "short_rest",
        /* required, allowed values - 1/2/3 */
        "subclass_mastery": 1,
        "attacks": [
          {
            /* required, allowed locale keys - en, ru, es */
            "name": {
              "en": "Ability weapon's name"
            },
            /* required, allowed locale keys - en, ru, es */
            "description": {
              "en": "Ability weapon's description, **Markdown is available** for editing."
            },
            /* required, primary weapon or secondary weapon */
            "kind": "primary weapon",
            "info": {
              /* required, 1 or 2 */
              "burden": 1,
              /* required, from 1 to 4 */
              "tier": 1,
              /* required */
              /* agi, str, fin, ins, pre, know */
              "trait": "agi",
              /* required */
              /* melee, very close, close, far, very far */
              "range": "very close",
              /* required */
              /* physical or magic */
              "damage_type": "physical",
              /* required */
              /* d4, d6, d8, d10, d12, d20 */
              "damage": "d10",
              /* required, from 0 to 20 */
              "damage_bonus": 1,
              /* optional, list of features */
              "features": [
                {
                  /* required, allowed locale keys - en, ru, es */
                  "en": "Feature"
                }
              ]
            }
          }
        ]
      }
    ]
  }
]
