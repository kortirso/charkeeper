[
  {
    /* required, allowed locale keys - en, ru, es */
    "title": {
      "en": "Class's title"
    },
    /* required, allowed locale keys - en, ru, es */
    "description": {
      "en": "Class's description, **Markdown is available** for editing."
    },
    "public": true,
    /* required, list of domains for class, max 2 */
    /* arcana, blade, bone, codex, grace, midnight, sage, splendor, valor, dread or ID of homebrew domain */
    "domains": ["arcana", "blade"],
    /* required, evasion - from 1 to 20 */
    "evasion": 6,
    /* required, start health - from 1 to 10 */
    "health_max": 6,
    "features": [
      {
        /* required, allowed locale keys - en, ru, es */
        "title": {
          "en": "Feature's title"
        },
        /* required, allowed locale keys - en, ru, es */
        "description": {
          "en": "Feature's description, **Markdown is available** for editing."
        },
        /* required, allowed values - static/text/update_result/hidden */
        /* static - Simple rendering */
        /* text - Like static + allow to add text value */
        /* update_result - Like static + can be hidden by settings */
        /* hidden - Always hidden */
        "kind": "static",
        /* optional */
        "limit": 1,
        /* optional, allowed values - short_rest/long_rest/session */
        "limit_refresh": "short_rest",
        /* optional, hope or stress */
        "price": { "hope": 1 },
        /* optional */
        /* available keys - str/agi/fin/ins/pre/know/health/stress/hope/evasion/armor_score/major/severe/attack/damage/spell_bonus */
        /* type - add */
        /* value - integer or formula */
        /* formulas - "level", "tier", "proficiency", "tier * 2", "level + 2" */
        "modifiers": {
          "spell_bonus": { "type": "add", "value": 2 },
          "severe": { "type": "add", "value": "tier" }
        },
        /* optional, if feature changes hope or fear dice - D4, D6, D8, D10, D12, D20 */
        "hope_dice": "D20",
        "fear_dice": "D12",
        /* optional, if feature can be enabled/disabled */
        "continious": true,
        /* optional, counting tokens */
        "tokens": {
          /* optional, none/str/agi/fin/ins/pre/know/spellcast/level/tier/proficiency or number */
          "limit": "proficiency",
          /* optional, reset current tokens at, long/short/session */
          "reset_at": "long",
          /* optional, zero/limit */
          "reset": "limit"
        },
        /* optional, excluded features when current feature is selected */
        /* with this option feature can boosted and overwrite simple version */
        /* you can see ids during updating features */
        "exclude": ["ID1", "ID2"]
      },
      {
        "title": {
          "en": "Feature's title"
        },
        "description": {
          "en": "Feature's description, **Markdown is available** for editing."
        },
        "kind": "static",
        "attacks": [
          {
            /* required, allowed locale keys - en, ru, es */
            "name": {
              "en": "Ability weapon's name"
            },
            /* required, allowed locale keys - en, ru, es */
            "description": {
              "en": "Ability weapon's description, **Markdown is available** for editing."
            },
            /* required, primary weapon or secondary weapon */
            "kind": "primary weapon",
            "info": {
              /* required, 1 or 2 */
              "burden": 1,
              /* required, from 1 to 4 */
              "tier": 1,
              /* required */
              /* agi, str, fin, ins, pre, know */
              "trait": "agi",
              /* required */
              /* melee, very close, close, far, very far */
              "range": "very close",
              /* required */
              /* physical or magic */
              "damage_type": "physical",
              /* required */
              /* d4, d6, d8, d10, d12, d20 */
              "damage": "d10",
              /* required, from 0 to 20 */
              "damage_bonus": 1,
              /* optional, list of features */
              "features": [
                {
                  /* required, allowed locale keys - en, ru, es */
                  "en": "Feature"
                }
              ]
            }
          }
        ]
      }
    ]
  }
]
